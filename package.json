{
  "name": "help-with-prison-visits-internal",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ministryofjustice/help-with-prison-visits-internal.git"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "scripts": {
    "build": "./build",
    "start": "node $NODE_OPTIONS ./app/bin/www | bunyan -o short",
    "start:dev": "npm run css-build && node --env-file=.env ./app/bin/www",
    "security_audit": "npx audit-ci --config audit-ci.json",
    "test": "npm run lint && npm run test-unit",
    "test-unit": "jest",
    "test:ci": "jest --runInBand --coverage",
    "test-coverage": "nyc npm run test-unit",
    "test-integration": "KNEX_CONFIG=testing mocha --recursive test/integration/ --timeout 15000 --exit",
    "test-e2e": "KNEX_CONFIG=testing cypress run --config video=false",
    "test-e2e-ui": "KNEX_CONFIG=testing cypress open",
    "css-build": "sass --no-source-map --quiet-deps --load-path=node_modules/govuk-frontend/dist --load-path=node_modules/@ministryofjustice/frontend --load-path=. ./app/assets/sass/application.scss ./app/public/stylesheets/application.css",
    "lint": "eslint . --cache --max-warnings 0",
    "lint-fix": "eslint . --fix",
    "setup": "npm ci && hmpps-npm-script-run-allowlist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@ministryofjustice/frontend": "9.0.0",
    "@ministryofjustice/hmpps-monitoring": "1.0.2",
    "applicationinsights": "^2.9.8",
    "bluebird": "^3.7.2",
    "bunyan": "^1.8.15",
    "bunyan-format": "^0.2.1",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "csrf-sync": "4.2.1",
    "csv-stringify": "^6.7.0",
    "datatables.net": "^2.3.7",
    "datatables.net-dt": "^2.3.7",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "govuk-frontend": "^6.1.0",
    "helmet": "^8.1.0",
    "jquery": "^4.0.0",
    "knex": "^3.2.9",
    "moment": "^2.30.1",
    "multer": "^2.1.1",
    "nunjucks": "^3.2.4",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.8.0",
    "redis": "^5.12.1",
    "sanitize-html": "^2.17.3",
    "tedious": "^19.2.1",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@ministryofjustice/eslint-config-hmpps": "^1.0.3",
    "@ministryofjustice/hmpps-npm-script-allowlist": "0.0.4",
    "chokidar": "3.6.0",
    "cypress": "^15.14.0",
    "jest": "^30.3.0",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^16.0.0",
    "node-mocks-http": "^1.17.2",
    "nyc": "^18.0.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "supertest": "^7.2.2"
  }
}
